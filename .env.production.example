# ============================================
# KnowledgeBot SaaS - PRODUCCIÓN (VPS Hostinger)
# ============================================
# IMPORTANTE: Este archivo NUNCA debe subirse a GitHub.
# Está listado en .gitignore. Créalo manualmente en el VPS.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://aqgutgpbivucnshshpsr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PEGAR_TU_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=PEGAR_TU_SERVICE_ROLE_KEY

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=PEGAR_TU_OPENROUTER_API_KEY
CHAT_MODEL=google/gemini-2.5-flash

# --- Embeddings (RAG) ---
EMBEDDINGS_API_KEY=PEGAR_TU_OPENAI_API_KEY
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small
RAG_MATCH_THRESHOLD=0.10

# --- Google OAuth (Calendario) ---
GOOGLE_CLIENT_ID=PEGAR_TU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=PEGAR_TU_GOOGLE_CLIENT_SECRET
# IMPORTANTE: Cambia localhost por el dominio real de tu VPS
GOOGLE_OAUTH_REDIRECT_URI=https://TU_DOMINIO.com/api/auth/google/callback

# --- Encryption ---
ENCRYPTION_KEY=PEGAR_TU_CLAVE_32_BYTES_BASE64

# --- WhatsApp Bridge ---
# El puente corre en el mismo VPS en localhost:3004 (host network mode)
WHATSAPP_BRIDGE_URL=http://localhost:3004
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_API_KEY=PEGAR_TU_BRIDGE_SECRET

# --- App URL ---
# Cambia esto por el dominio o IP de tu VPS
NEXT_PUBLIC_APP_URL=https://TU_DOMINIO.com
