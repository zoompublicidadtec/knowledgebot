# ============================================
# KnowledgeBot SaaS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenRouter (LLM: DeepSeek for chat) ---
OPENROUTER_API_KEY=your-openrouter-api-key
CHAT_MODEL=google/gemini-2.5-flash

# --- Embeddings Provider (RAG vector memory) ---
# Uses an OpenAI-compatible /embeddings endpoint.
# Default model produces 1536 dimensions, matching the Supabase vector(1536) schema.
EMBEDDINGS_API_KEY=your-openai-or-embeddings-api-key
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small
RAG_MATCH_THRESHOLD=0.35

# --- Google OAuth (Calendar only) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3003/api/auth/google/callback

# --- Encryption ---
# 32 bytes base64 encoded key for AES-256-GCM.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-32-byte-base64-key

# --- WhatsApp Bridge ---
# URL of the wa-server-knowledge service. In Railway this is the public URL.
# For local dev with docker-compose (host network mode), use http://localhost:3004
WHATSAPP_BRIDGE_URL=http://localhost:3004

# Shared secret between the SaaS and the bridge. BOTH services must have the same value.
# In local dev you can leave empty (auth is disabled).
# In Railway, generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3003
